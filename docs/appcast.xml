            <enclosure url="https://github.com/kmatzen/lede/releases/download/v0.1.3/Lede-0.1.3.dmg"
                       type="application/octet-stream"
                       sparkle:edSignature="x2AhJChaWomRwVV5KiFDD4ygXu0tTvbCkiVtdS1+m/2/fRUWLQJfjros+I7OzN47yJMKk2NI0GHmkQC722FVAw==" length="6350624" />
