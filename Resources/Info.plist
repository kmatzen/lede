        Sparkle auto-update. Replace with your hosted appcast.xml URL and
        the EdDSA public key generated by `generate_keys` (ships with
        Sparkle). Until both are real values, Sparkle silently no-ops.
    -->
    <key>SUFeedURL</key>
    <string>https://example.com/lede/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string></string>
    <key>SUEnableInstallerLauncherService</key>
    <false/>
</dict>
